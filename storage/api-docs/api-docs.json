                    }
                }
            }
        },
        "/api/v1/auth/yandex": {
            "get": {
                "tags": [
                    "Авторизация"
                ],
                "summary": "Yandex авторизация",
                "description": "Будет произведён редирект на страницу авторизации Яндекс. После успешной авторизации, пользователь будет перенаправлен на указанный в настройках приложения URL.",
                "operationId": "33e3ebe55ed74d89af3f7957e34a647b",
                "responses": {
                    "302": {
                        "description": "Redirect to Yandex",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "redirect"
                                        },
                                        "url": {
                                            "type": "string",
                                            "example": "https://oauth.yandex.ru/authorize"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
