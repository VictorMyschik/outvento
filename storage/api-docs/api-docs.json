                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/AuthError"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ValidationError"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/NotFoundError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/user/verify/resend": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Повторная отправка кода верификации",
                "description": "Повторная отправка кода верификации на email пользователя. Код будет отправлен на email, указанный при регистрации.",
                "operationId": "verifyResend",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/XRequestedWithHeader"
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Successful",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/SuccessfulEmptyResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/AuthError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/reset-password/code": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Отправка кода сброса пароля",
                "description": "Отправка кода для сброса пароля на email пользователя.",
                "operationId": "resetPasswordCode",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/XRequestedWithHeader"
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ResetPasswordRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "204": {
                        "description": "Successful",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/SuccessfulEmptyResponse"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ValidationError"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/NotFoundError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/reset-password/change": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Изменение пароля",
                "description": "Изменение пароля пользователя с использованием кода сброса.",
                "operationId": "resetPasswordChange",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/XRequestedWithHeader"
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ChangePasswordRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "204": {
                        "description": "Successful",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/SuccessfulEmptyResponse"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ValidationError"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/NotFoundError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/common/languages": {
            "get": {
                "tags": [
                    "Common"
                ],
                "summary": "Get available languages",
                "operationId": "getLanguages",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/XRequestedWithHeader"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "required": [
                                        "status",
                                        "content"
                                    ],
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "ok"
                                        },
                                        "content": {
                                            "$ref": "#/components/schemas/LanguagesResponse"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/locale/{locale}": {
            "post": {
                "tags": [
                    "Common"
                ],
                "summary": "Установить локаль пользователя",
                "operationId": "setLocale",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/XRequestedWithHeader"
                    },
                    {
                        "name": "locale",
                        "in": "path",
                        "description": "Код локали (например: en, ru)",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "en"
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Successful",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/SuccessfulEmptyResponse"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Bad Request",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ValidationError"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {},
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/v1/user": {
            "get": {
                "tags": [
                    "User info"
                ],
                "summary": "Получить информацию о текущем пользователе",
                "operationId": "profile",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/XRequestedWithHeader"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "required": [
                                        "status",
                                        "content"
                                    ],
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "ok"
                                        },
                                        "content": {
                                            "$ref": "#/components/schemas/UserProfileResponse"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/AuthError"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/v1/user/profile": {
            "post": {
                "tags": [
                    "User info"
                ],
                "summary": "Обновить информацию о пользователе",
                "operationId": "updateProfile",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/XRequestedWithHeader"
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/UpdateProfileRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Profile updated successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "ok"
                                        },
                                        "content": {
                                            "$ref": "#/components/schemas/UserProfileResponse"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Bad Request",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ValidationError"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/AuthError"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/v1/user/password": {
            "post": {
                "tags": [
                    "User info"
                ],
                "summary": "Изменить пароль пользователя",
                "operationId": "changePassword",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/XRequestedWithHeader"
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/UpdatePasswordRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "204": {
                        "description": "Successful",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/SuccessfulEmptyResponse"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Bad Request",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ValidationError"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/AuthError"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/v1/user/avatar": {
            "delete": {
                "tags": [
                    "User info"
                ],
                "summary": "Удалить аватар пользователя",
                "operationId": "removeAvatar",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/XRequestedWithHeader"
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Successful",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/SuccessfulEmptyResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/AuthError"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        }
    },
    "components": {
        "schemas": {
            "AuthenticateRequest": {
                "required": [
                    "email",
                    "password"
                ],
                "properties": {
                    "email": {
                        "type": "string",
                        "format": "email",
                        "maxLength": 255,
                        "example": "user@example.com"
                    },
                    "password": {
                        "type": "string",
                        "example": "password123"
                    }
                },
                "type": "object"
            },
            "ChangePasswordRequest": {
                "required": [
                    "email",
                    "code",
                    "password"
                ],
                "properties": {
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "user@example.com"
                    },
                    "code": {
                        "type": "string",
                        "example": "123456"
                    },
                    "password": {
                        "type": "string",
                        "format": "password",
                        "example": "newPassword123"
                    }
                },
                "type": "object"
            },
            "InviteUsersRequest": {
                "required": [
                    "emails"
                ],
                "properties": {
                    "emails": {
                        "description": "List of email addresses to invite",
                        "type": "array",
                        "items": {
                            "type": "string",
                            "format": "email"
                        }
                    }
                },
                "type": "object"
            },
            "RegisterRequest": {
                "required": [
                    "name",
                    "email",
                    "password"
                ],
                "properties": {
                    "name": {
                        "type": "string",
                        "maxLength": 255,
                        "example": "John"
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "maxLength": 255,
                        "example": "john.doe@example.com"
                    },
                    "password": {
                        "type": "string",
                        "format": "password",
                        "example": "password123"
                    },
                    "password_confirmation": {
                        "type": "string",
                        "format": "password",
                        "example": "password123"
                    }
                },
                "type": "object"
            },
            "ResetPasswordRequest": {
                "required": [
                    "email"
                ],
                "properties": {
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "user@example.com"
                    }
                },
                "type": "object"
            },
            "UpdatePasswordRequest": {
                "required": [
                    "current_password",
                    "password"
                ],
                "properties": {
                    "current_password": {
                        "type": "string",
                        "example": "currentPassword123"
                    },
                    "password": {
                        "type": "string",
                        "format": "password",
                        "example": "newPassword123"
                    },
                    "password_confirmation": {
                        "type": "string",
                        "format": "password",
                        "example": "newPassword123"
                    }
                },
                "type": "object"
            },
            "VerifyRegistrationRequest": {
                "required": [
                    "code"
                ],
                "properties": {
                    "code": {
                        "type": "string",
                        "format": "digits",
                        "example": "123456"
                    }
                },
                "type": "object"
            },
            "LoginResponseContent": {
                "required": [
                    "token"
                ],
                "properties": {
                    "token": {
                        "type": "string",
                        "enum": [
                            "ok"
                        ],
                        "example": "54|zSA0wCsYADhnwylBCo86NPCKnz1jEYGns7cJbY8543e3b2ad"
                    }
                },
                "type": "object"
            },
            "LanguagesResponse": {
                "description": "Response containing available languages mapped by locale code",
                "required": [
                    "languages"
                ],
                "properties": {
                    "languages": {
                        "description": "Mapping of locale code to label",
                        "type": "object",
                        "additionalProperties": {
                            "type": "string",
                            "example": "English"
                        }
                    }
                },
                "type": "object",
                "example": {
                    "languages": {
                        "en": "English",
                        "ru": "Русский",
                        "pl": "Polski"
                    }
                }
            },
            "Pagination": {
                "properties": {
                    "quantity": {
                        "description": "Количество элементов на странице",
                        "type": "integer"
                    },
                    "totalQuantity": {
                        "description": "Общее количество элементов",
                        "type": "integer"
                    },
                    "currentPage": {
                        "description": "Текущая страница",
                        "type": "integer"
                    },
                    "pages": {
                        "description": "Общее количество страниц",
                        "type": "integer"
                    }
                },
                "type": "object"
            },
            "UpdateProfileRequest": {
