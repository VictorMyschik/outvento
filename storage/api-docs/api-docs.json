    "components": {
        "schemas": {
            "AuthenticateRequest": {
                "required": [
                    "email",
                    "password"
                ],
                "properties": {
                    "email": {
                        "type": "string",
                        "format": "email",
                        "maxLength": 255,
                        "example": "user@example.com"
                    },
                    "password": {
                        "type": "string",
                        "example": "password123"
                    }
                },
                "type": "object"
            },
            "ChangePasswordRequest": {
                "required": [
                    "email",
                    "code",
                    "password"
                ],
                "properties": {
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "user@example.com"
                    },
                    "code": {
                        "type": "string",
                        "example": "123456"
                    },
                    "password": {
                        "type": "string",
                        "format": "password",
                        "example": "newPassword123"
                    }
                },
                "type": "object"
            },
            "InviteUsersRequest": {
                "required": [
                    "emails"
                ],
                "properties": {
                    "emails": {
                        "description": "List of email addresses to invite",
                        "type": "array",
                        "items": {
                            "type": "string",
                            "format": "email"
                        }
                    }
                },
                "type": "object"
            },
            "RegisterRequest": {
                "required": [
                    "name",
                    "email",
                    "password"
                ],
                "properties": {
                    "name": {
                        "type": "string",
                        "maxLength": 255,
                        "example": "John"
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "maxLength": 255,
                        "example": "john.doe@example.com"
                    },
                    "password": {
                        "type": "string",
                        "format": "password",
                        "example": "password123"
                    },
                    "password_confirmation": {
                        "type": "string",
                        "format": "password",
                        "example": "password123"
                    }
                },
                "type": "object"
            },
            "ResetPasswordRequest": {
                "required": [
                    "email"
                ],
                "properties": {
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "user@example.com"
                    }
                },
                "type": "object"
            },
            "UpdatePasswordRequest": {
                "required": [
                    "current_password",
                    "password"
                ],
                "properties": {
                    "current_password": {
                        "type": "string",
                        "example": "currentPassword123"
                    },
                    "password": {
                        "type": "string",
                        "format": "password",
                        "example": "newPassword123"
                    },
                    "password_confirmation": {
                        "type": "string",
                        "format": "password",
                        "example": "newPassword123"
                    }
                },
                "type": "object"
            },
            "VerifyRegistrationRequest": {
                "required": [
                    "code"
                ],
                "properties": {
                    "code": {
                        "type": "string",
                        "format": "digits",
                        "example": "123456"
                    }
                },
                "type": "object"
            },
            "Pagination": {
                "properties": {
                    "quantity": {
                        "description": "Количество элементов на странице",
                        "type": "integer"
                    },
                    "totalQuantity": {
                        "description": "Общее количество элементов",
                        "type": "integer"
                    },
                    "currentPage": {
                        "description": "Текущая страница",
                        "type": "integer"
                    },
                    "pages": {
                        "description": "Общее количество страниц",
                        "type": "integer"
                    }
                },
                "type": "object"
            },
            "UpdateProfileRequest": {
                "required": [
                    "first_name",
                    "last_name",
                    "phone",
                    "email"
                ],
                "properties": {
                    "first_name": {
                        "type": "string",
                        "maxLength": 255,
                        "example": "John",
                        "nullable": true
                    },
                    "last_name": {
                        "type": "string",
                        "maxLength": 255,
                        "example": "Doe",
                        "nullable": true
                    },
                    "phone": {
                        "type": "string",
                        "example": "+1234567890",
                        "nullable": true
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "maxLength": 255,
                        "example": "user@example.com",
                        "nullable": true
                    },
                    "avatar": {
                        "type": "string",
                        "format": "binary",
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "UserProfileResponse": {
                "properties": {
                    "id": {
                        "description": "Идентификатор пользователя",
                        "type": "integer",
                        "format": "int64"
                    },
                    "firstName": {
                        "description": "Имя пользователя",
                        "type": "string"
                    },
                    "lastName": {
                        "description": "Фамилия пользователя",
                        "type": "string"
                    },
                    "phone": {
                        "description": "Номер телефона пользователя",
                        "type": "string"
                    },
                    "email": {
                        "description": "Адрес электронной почты пользователя",
                        "type": "string"
